@model AdminPanel.ViewModels.RegisterViewModel

@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Kayıt Ol";
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i> @ViewBag.Message
    </div>
    <div class="text-center mt-3">
        <a asp-action="Login" class="btn btn-outline-light">Giriş Sayfasına Dön</a>
    </div>
}
else
{
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="form-control bg-dark border-secondary text-white" placeholder="ornek@mail.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-lock"></i></span>
                <input asp-for="Password" class="form-control bg-dark border-secondary text-white" placeholder="Şifreniz" />
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="ConfirmPassword" class="form-control bg-dark border-secondary text-white" placeholder="Şifrenizi tekrar girin" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-person-plus me-2"></i> Kayıt Ol
        </button>
    </form>

    <hr class="border-secondary mb-3" />

    <form asp-action="ExternalLogin" method="post" class="mb-3">
        <input type="hidden" name="provider" value="Google" />
        <button type="submit" class="btn btn-google w-100">
            <i class="bi bi-google me-2"></i> Google ile Kayıt Ol
        </button>
    </form>

    <div class="text-center">
        <span class="text-muted">Zaten hesabınız var mı?</span> <a asp-action="Login" class="text-decoration-none">Giriş Yap</a>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
