@model AdminPanel.Models.Project
@{
    ViewData["Title"] = Model.SiteName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@Model.SiteName</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Düzenle</a>
        <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Geri Dön</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card h-100 bg-transparent border-secondary">
            @if(!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="card-img-top img-fluid" alt="@Model.SiteName" style="max-height: 400px; object-fit: cover;">
            }
            else
            {
                <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 400px;">
                    <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
                </div>
            }
            <div class="card-body">
                <h4 class="card-title">Proje Detayları</h4>
                <p class="card-text text-light" style="white-space: pre-line;">@Model.Description</p>
                
                <h5 class="mt-4 mb-3">Kullanılan Teknolojiler</h5>
                <div>
                    @if(Model.ProjectTechnologies != null && Model.ProjectTechnologies.Any())
                    {
                        foreach (var pt in Model.ProjectTechnologies)
                        {
                            <span class="badge tech-badge fs-6 me-2 mb-2 p-2"><i class="bi bi-code-slash"></i> @pt.Technology.Name</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Teknoloji belirtilmemiş.</span>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card bg-transparent border-secondary mb-4">
            <div class="card-header bg-transparent border-secondary">
                <h5 class="mb-0">Genel Bilgiler</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush bg-transparent">
                    <li class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center">
                        Durum
                        <span class="badge badge-@Model.Status p-2">@Model.Status</span>
                    </li>
                    <li class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center">
                        Oluşturulma
                        <span class="text-muted">@Model.CreatedDate.ToString("dd MMMM yyyy HH:mm")</span>
                    </li>
                    <li class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center">
                        Son Güncelleme
                        <span class="text-muted">@Model.UpdatedDate.ToString("dd MMMM yyyy HH:mm")</span>
                    </li>
                    <li class="list-group-item bg-transparent text-light border-secondary">
                        <div class="mb-1">Site Bağlantısı</div>
                        <a href="@Model.SiteUrl" target="_blank" class="text-info text-decoration-none text-break"><i class="bi bi-box-arrow-up-right"></i> @Model.SiteUrl</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card bg-transparent border-secondary">
            <div class="card-header bg-transparent border-secondary">
                <h5 class="mb-0">Ziyaretçi İstatistikleri</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 border-end border-secondary">
                        <div class="text-muted mb-2">Günlük Ziyaretçi</div>
                        <h3 class="text-primary mb-0">@Model.DailyVisitors</h3>
                    </div>
                    <div class="col-6">
                        <div class="text-muted mb-2">Toplam Ziyaretçi</div>
                        <h3 class="text-success mb-0">@Model.TotalVisitors</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
